#compdef sm

autoload -U is-at-least

_sm() {
    typeset -A opt_args
    typeset -a _arguments_options
    local ret=1

    if is-at-least 5.2; then
        _arguments_options=(-s -S -C)
    else
        _arguments_options=(-s -C)
    fi

    local context curcontext="$curcontext" state line
    _arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_sm_commands" \
"*::: :->sm" \
&& ret=0
    case $state in
    (sm)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:sm-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
":: :_sm__add_commands" \
"*::: :->add" \
&& ret=0

    case $state in
    (add)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:sm-add-command-$line[1]:"
        case $line[1] in
            (alias)
_arguments "${_arguments_options[@]}" : \
'-d[Directory-specific flag]' \
'--directory[Directory-specific flag]' \
'-l[Long alias flag]' \
'--long[Long alias flag]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':name -- The name of the alias:' \
'::value -- The command to be aliased, if not provided, the last command fromm the history will be used:' \
&& ret=0
;;
(path)
_arguments "${_arguments_options[@]}" : \
'-d[Directory-specific flag]' \
'--directory[Directory-specific flag]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':name -- The name of the path:' \
':value -- The path to be added:' \
&& ret=0
;;
(secret)
_arguments "${_arguments_options[@]}" : \
'-d[Directory-specific flag]' \
'--directory[Directory-specific flag]' \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':name -- The name of the secret:' \
':value -- The secret value:' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_sm__add__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:sm-add-help-command-$line[1]:"
        case $line[1] in
            (alias)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(path)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(secret)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
;;
(env)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
'-h[Print help]' \
'--help[Print help]' \
'-V[Print version]' \
'--version[Print version]' \
':shell -- The shell to initialize:' \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
":: :_sm__help_commands" \
"*::: :->help" \
&& ret=0

    case $state in
    (help)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:sm-help-command-$line[1]:"
        case $line[1] in
            (add)
_arguments "${_arguments_options[@]}" : \
":: :_sm__help__add_commands" \
"*::: :->add" \
&& ret=0

    case $state in
    (add)
        words=($line[1] "${words[@]}")
        (( CURRENT += 1 ))
        curcontext="${curcontext%:*:*}:sm-help-add-command-$line[1]:"
        case $line[1] in
            (alias)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(path)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(secret)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
(env)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(init)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
(help)
_arguments "${_arguments_options[@]}" : \
&& ret=0
;;
        esac
    ;;
esac
;;
        esac
    ;;
esac
}

(( $+functions[_sm_commands] )) ||
_sm_commands() {
    local commands; commands=(
'add:Add a new alias, path, or secret' \
'env:Load environment variables into the current shell' \
'init:Initialize the shell-manager for your shell, usually put \`eval "\$(sm init)"\` in your shell rc file' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'sm commands' commands "$@"
}
(( $+functions[_sm__add_commands] )) ||
_sm__add_commands() {
    local commands; commands=(
'alias:Add a new alias' \
'path:Add a new path' \
'secret:Add a new secret' \
'help:Print this message or the help of the given subcommand(s)' \
    )
    _describe -t commands 'sm add commands' commands "$@"
}
(( $+functions[_sm__add__alias_commands] )) ||
_sm__add__alias_commands() {
    local commands; commands=()
    _describe -t commands 'sm add alias commands' commands "$@"
}
