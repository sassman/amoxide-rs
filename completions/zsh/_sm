    )
    _describe -t commands 'sm help add commands' commands "$@"
}
(( $+functions[_sm__help__add__alias_commands] )) ||
_sm__help__add__alias_commands() {
    local commands; commands=()
    _describe -t commands 'sm help add alias commands' commands "$@"
}
(( $+functions[_sm__help__add__path_commands] )) ||
_sm__help__add__path_commands() {
    local commands; commands=()
    _describe -t commands 'sm help add path commands' commands "$@"
}
(( $+functions[_sm__help__add__secret_commands] )) ||
_sm__help__add__secret_commands() {
    local commands; commands=()
    _describe -t commands 'sm help add secret commands' commands "$@"
}
(( $+functions[_sm__help__env_commands] )) ||
_sm__help__env_commands() {
    local commands; commands=()
    _describe -t commands 'sm help env commands' commands "$@"
}
(( $+functions[_sm__help__help_commands] )) ||
_sm__help__help_commands() {
    local commands; commands=()
    _describe -t commands 'sm help help commands' commands "$@"
}
(( $+functions[_sm__help__init_commands] )) ||
_sm__help__init_commands() {
    local commands; commands=()
    _describe -t commands 'sm help init commands' commands "$@"
}
(( $+functions[_sm__init_commands] )) ||
_sm__init_commands() {
    local commands; commands=()
    _describe -t commands 'sm init commands' commands "$@"
}

if [ "$funcstack[1]" = "_sm" ]; then
    _sm "$@"
else
    compdef _sm sm
fi
