}

if [[ "${BASH_VERSINFO[0]}" -eq 4 && "${BASH_VERSINFO[1]}" -ge 4 || "${BASH_VERSINFO[0]}" -gt 4 ]]; then
    complete -F _am -o nosort -o bashdefault -o default am
else
    complete -F _am -o bashdefault -o default am
fi
