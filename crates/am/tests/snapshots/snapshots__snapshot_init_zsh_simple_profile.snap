---
source: crates/am/tests/snapshots.rs
expression: output
---
gs() { git status "$@"; }
ll() { ls -lha "$@"; }
export _AM_ALIASES="gs,ll"

am() {
  command am "$@"
  case "$1:$2" in
    profile:set|p:set|profile:s|p:s) eval "$(command am reload zsh)" ;;
  esac
  case "$1" in
    add|a|remove|r)
      case "$*" in
        *\ -l\ *|*\ --local\ *|*\ -l|*\ --local) eval "$(command am hook zsh)" ;;
        *) eval "$(command am reload zsh)" ;;
      esac ;;
  esac
}

# am cd hook
__am_hook() { eval "$(am hook zsh)"; }
chpwd_functions+=(__am_hook)
__am_hook
