---
source: crates/am/tests/snapshots.rs
expression: output
---
gs() { git status "$@"; }
ll() { ls -lha "$@"; }
export _AM_ALIASES="gs,ll"
unset _AM_PROFILE_ALIASES

am() {
  command am "$@"
  local am_status=$?
  if [[ $am_status -ne 0 ]]; then return $am_status; fi
  case "$1:$2" in
    profile:set|p:set|profile:s|p:s|profile:add|p:add|profile:a|p:a|profile:remove|p:remove|profile:r|p:r) eval "$(command am reload zsh)" ;;
  esac
  case "$1" in
    add|a|remove|r)
      case "$*" in
        *\ -l\ *|*\ --local\ *|*\ -l|*\ --local) eval "$(command am hook zsh)" ;;
        *) eval "$(command am reload zsh)" ;;
      esac ;;
  esac
}

# am cd hook
__am_hook() { eval "$(am hook zsh)"; }
chpwd_functions+=(__am_hook)
__am_hook
