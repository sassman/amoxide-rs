---
source: crates/am/tests/snapshots.rs
expression: output
---
if (Test-Path Function:\gs) { Remove-Item Function:\gs }
if (Test-Path Function:\cm) { Remove-Item Function:\cm }
function global:cm { git commit -sm @args }
function global:cmf { cm feat: $args }
function global:gs { git status @args }
$env:_AM_ALIASES = "cm,cmf,gs"
