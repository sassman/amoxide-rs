---
source: crates/am/tests/snapshots.rs
expression: output
---
function gs { git status @args }
function ll { ls -lha @args }
$env:_AM_ALIASES = "gs,ll"
Remove-Item -ErrorAction SilentlyContinue Env:_AM_PROFILE_ALIASES

# am wrapper: reload aliases after mutations
function am {
    $amBin = (Get-Command -CommandType Application am | Select-Object -First 1).Source
    & $amBin @args
    if ($LASTEXITCODE -ne 0) { return }
    # tui — always reload
    if ($args.Count -ge 1 -and $args[0] -in 'tui', 't') {
        $out = (& $amBin reload powershell) -join "`n"
        if ($out) { Invoke-Expression $out }
        $out = (& $amBin hook powershell) -join "`n"
        if ($out) { Invoke-Expression $out }
        return
    }
    # profile mutation — reload
    if ($args.Count -ge 1 -and $args[0] -in 'profile', 'p') {
        if ($args.Count -ge 2 -and $args[1] -in 'set', 's', 'use', 'u', 'add', 'a', 'remove', 'r') {
            $out = (& $amBin reload powershell) -join "`n"
            if ($out) { Invoke-Expression $out }
        }
    }
    # alias mutation — reload
    elseif ($args.Count -ge 1 -and $args[0] -in 'add', 'a', 'remove', 'r') {
        if ($args -contains '-l' -or $args -contains '--local') {
            $out = (& $amBin hook powershell) -join "`n"
            if ($out) { Invoke-Expression $out }
        } else {
            $out = (& $amBin reload powershell) -join "`n"
            if ($out) { Invoke-Expression $out }
        }
    }
}


# am cd hook: track directory changes and reload project aliases
$env:__AM_LAST_DIR = $PWD.Path
$__am_original_prompt = $function:prompt
function prompt {
    if ($PWD.Path -ne $env:__AM_LAST_DIR) {
        $env:__AM_LAST_DIR = $PWD.Path
        $hookOutput = (& am hook powershell) -join "`n"
        if ($hookOutput) { Invoke-Expression $hookOutput }
    }
    & $__am_original_prompt
}
