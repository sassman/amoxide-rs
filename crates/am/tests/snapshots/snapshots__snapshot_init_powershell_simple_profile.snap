            [System.Management.Automation.CompletionResult]::new('setup', 'setup', [System.Management.Automation.CompletionResultType]::ParameterValue, 'Guided setup — adds amoxide to your shell profile')
            [System.Management.Automation.CompletionResult]::new('tui', 'tui', [System.Management.Automation.CompletionResultType]::ParameterValue, 'Launch the interactive TUI for managing aliases and profiles')
