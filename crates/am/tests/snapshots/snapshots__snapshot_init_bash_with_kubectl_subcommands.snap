---
source: crates/am/tests/snapshots.rs
expression: output
---
kubectl() {
  case "$1" in
    apply)
      case "$2" in
        f) shift 2; command kubectl apply -f "$@" ;;
        *) command kubectl "$@" ;;
      esac
      ;;
    get)
      case "$2" in
        po) shift 2; command kubectl get pods "$@" ;;
        svc) shift 2; command kubectl get services "$@" ;;
        *) command kubectl "$@" ;;
      esac
      ;;
    logs)
      case "$2" in
        f) shift 2; command kubectl logs -f "$@" ;;
        *) command kubectl "$@" ;;
      esac
      ;;
    rollout)
      case "$2" in
        status) shift 2; command kubectl rollout status "$@" ;;
        *) command kubectl "$@" ;;
      esac
      ;;
    *) command kubectl "$@" ;;
  esac
}
export _AM_ALIASES="kubectl|e597aec"
export _AM_SUBCOMMANDS="kubectl:apply:f|ce5fb2d,kubectl:get:po|98de999,kubectl:get:svc|15a309b,kubectl:logs:f|1b79d5f,kubectl:rollout:status|da7ff14"
am() {
  command am "$@"
  local am_status=$?
  if [[ $am_status -ne 0 ]]; then return $am_status; fi
  case "$1" in
    add|a|remove|r|trust|tui|t)
      eval "$(command am sync bash)" ;;
    use|u|untrust)
      eval "$(command am sync --quiet bash)" ;;
    profile|p)
      case "$2" in
        use|u) eval "$(command am sync --quiet bash)" ;;
        add|a|remove|r) eval "$(command am sync bash)" ;;
      esac ;;
  esac
}

# am cd hook: sync project aliases on directory change
__am_hook() {
  local previous_exit_status=$?
  if [[ "${__am_prev_dir:-}" != "$PWD" ]]; then
    __am_prev_dir="$PWD"
    eval "$(command am sync bash)"
  fi
  return $previous_exit_status
}
if [[ "$(declare -p PROMPT_COMMAND 2>&1)" == "declare -a"* ]]; then
  case " ${PROMPT_COMMAND[*]} " in
    *" __am_hook "*) ;;
    *) PROMPT_COMMAND=(__am_hook "${PROMPT_COMMAND[@]}") ;;
  esac
else
  case ";${PROMPT_COMMAND:-};" in
    *";__am_hook;"*) ;;
    *) PROMPT_COMMAND="__am_hook${PROMPT_COMMAND:+;$PROMPT_COMMAND}" ;;
  esac
fi
__am_hook

